\"Wir kommunizieren gut miteinander.\",","    \"lektion\": 2,","    \"audio\": \"98.opus\",","    \"teil\": 5","  },","  {","    \"id\": 99,","    \"wort\": \"erwerben\",","    \"grammatik\": \"erwirbt, erwarb, hat erworben\",","    \"beispiel\": \"Im Ausland erwirbt man unbewusst Sprachkenntnisse beim Einkaufen.\",","    \"lektion\": 2,","    \"audio\": \"99.opus\",","    \"teil\": 5","  },","  {","    \"id\": 100,","    \"wort\": \"Korrektur\",","    \"grammatik\": \"die, Korrekturen (pl)\",","    \"beispiel\": \"Es ist nicht nötig, dass Eltern die Sprachfehler ihrer Kinder korrigieren.\",","    \"lektion\": 2,","    \"audio\": \"100.opus\",","    \"teil\": 5","  },","  {","    \"id\": 101,","    \"wort\": \"Aufbau\",","    \"grammatik\": \"der\",","    \"beispiel\": \"Das Ziel von Kindern beim Spracherwerb liegt im Aufbau von sozialen Kontakten.\",","    \"lektion\": 2,","    \"audio\": \"101.opus\",","    \"teil\": 5","  },","  {","    \"id\": 102,","    \"wort\": \"Lernen\",","    \"grammatik\": \"das\",","    \"beispiel\": \"Lernen beschreibt bewusste und explizite Vorgänge mit einer klaren Steuerung.\",","    \"lektion\": 2,","    \"audio\": \"102.opus\",","    \"teil\": 5","  },","  {","    \"id\": 103,","    \"wort\": \"Es ist ausreichende bewiesen, dass…\",","    \"grammatik\": \"Umwandlung in den Verbalstil\",","    \"beispiel\": \"Es gibt ausreichende Beweise, dass…\",","    \"lektion\": 2,","    \"audio\": \"103.opus\",","    \"teil\": 5","  },","  {","    \"id\": 104,","    \"wort\": \"daher nimmt man an, dass\",","    \"grammatik\": \"\",","    \"beispiel\": \"Es besteht daher die Annahme, dass…\",","    \"lektion\": 2,","    \"audio\": \"104.opus\",","    \"teil\": 5","  },","  {","    \"id\": 105,","    \"wort\": \"gelten\",","    \"grammatik\": \"gilt, galt, hat gegolten\",","    \"beispiel\": \"In Deutschland galt bis vor wenigen Jahren, wer Dialekt sprach, als ungebildet.\",","    \"lektion\": 2,","    \"audio\": \"105.opus\",","    \"teil\": 6","  },","  {","    \"id\": 106,","    \"wort\": \"wirken\",","    \"grammatik\": \"wirkt, wirkte, hat gewirkt\",","    \"beispiel\": \"Karikaturisten benutzen den Dialekt, um komischer zu wirken.\",","    \"lektion\": 2,","    \"audio\": \"106.opus\",","    \"teil\": 6","  },","  {","    \"id\": 107,","    \"wort\": \"im Grunde genommen\",","    \"grammatik\": \"\",","    \"beispiel\": \"Im Grunde genommen gibt es das Hochdeutsch in Reinform nur noch in der Tagesschau.\",","    \"lektion\": 2,","    \"audio\": \"107.opus\",","    \"teil\": 6","  },","  {","    \"id\": 108,","    \"wort\": \"verbreiten\",","    \"grammatik\": \"verbreitet, verbreitete, hat verbreitet\",","    \"beispiel\": \"Das Radio hat nicht nur Nachrichten verbreitet, sondern auch das Hochdeutsche im Land.\",","    \"lektion\": 2,","    \"audio\": \"108.opus\",","    \"teil\": 6","  },","  {","    \"id\": 109,","    \"wort\": \"rein\",","    \"grammatik\": \"\",","    \"beispiel\": \"Heute hören die Leute im Radio und Fernsehen keine reine Hochsprache mehr.\",","    \"lektion\": 2,","    \"audio\": \"109.opus\",","    \"teil\": 6","  },","  {","    \"id\": 110,","    \"wort\": \"betonen\",","    \"grammatik\": \"betont, betonte, hat betont\",","    \"beispiel\": \"In unzähligen SMS schrieben viele Dialekt, um den Unterschied zu den beruflichen Nachrichten zu betonen.\",","    \"lektion\": 2,","    \"audio\": \"110.opus\",","    \"teil\": 6","  },","  {","    \"id\": 111,","    \"wort\": \"zu tun haben\",","    \"grammatik\": \"mit + Dativ\",","    \"beispiel\": \"Die erneute Beliebtheit des Dialektes hat mit der Globalisierung zu tun.\",","    \"lektion\": 2,","    \"audio\": \"111.opus\",","    \"teil\": 6","  },","  {","    \"id\": 112,","    \"wort\": \"sich sehnen\",","    \"grammatik\": \"nach + Dativ\",","    \"beispiel\": \"Viele sehnen sich nach einer kleineren Welt, in der sie sich zurechtfinden.\",","    \"lektion\": 2,","    \"audio\": \"112.opus\",","    \"teil\": 6","  },","  {","    \"id\": 113,","    \"wort\": \"Meinung\",","    \"grammatik\": \"die, einer Meinung sein\",","    \"beispiel\": \"Viele Schweizer sind der Meinung, Hochdeutsch sei für sie eine Fremdsprache.\",","    \"lektion\": 2,","    \"audio\": \"113.opus\",","    \"teil\": 7","  },","  {","    \"id\": 114,","    \"wort\": \"nachvollziehen\",","    \"grammatik\": \"\",","    \"beispiel\": \"Ich kann nicht nachvollziehen, warum sich Schweizer weigern, Hochdeutsch zu sprechen.\",","    \"lektion\": 2,","    \"audio\": \"114.opus\",","    \"teil\": 7","  },","  {","    \"id\": 115,","    \"wort\": \"Ansicht\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Ich vertrete die Ansicht, dass das Schweizer Hochdeutsch eine gleichwertige Varietät des Deutschen ist.\",","    \"lektion\": 2,","    \"audio\": \"115.opus\",","    \"teil\": 7","  },","  {","    \"id\": 116,","    \"wort\": \"fest\",","    \"grammatik\": \"\",","    \"beispiel\": \"Wir sind der festen Überzeugung, dass der Dialekt den Schweizern nie als bäuerlich oder ungebildet vorkam.\",","    \"lektion\": 2,","    \"audio\": \"116.opus\",","    \"teil\": 7","  },","  {","    \"id\": 117,","    \"wort\": \"einleuchtend\",","    \"grammatik\": \"\",","    \"beispiel\": \"Findest du es einleuchtend, dass Deutsch- und Welschschweizer sich oft auf Englisch unterhalten?\",","    \"lektion\": 2,","    \"audio\": \"117.opus\",","    \"teil\": 7","  },","  {","    \"id\": 118,","    \"wort\": \"erhalten\",","    \"grammatik\": \"erhält, erhielt, hat erhalten\",","    \"beispiel\": \"Dialekte sind ein Teil der Kultur und müssen erhalten werden.\",","    \"lektion\": 2,","    \"audio\": \"118.opus\",","    \"teil\": 7","  },","  {","    \"id\": 119,","    \"wort\": \"schaffen\",","    \"grammatik\": \"schafft, schuf, hat geschaffen\",","    \"beispiel\": \"Der Dialekt verbindet Menschen und schafft eine Gemeinschaft.\",","    \"lektion\": 2,","    \"audio\": \"119.opus\",","    \"teil\": 7","  },","  {","    \"id\": 120,","    \"wort\": \"wichtig\",","    \"grammatik\": \"für + Akkusativ\",","    \"beispiel\": \"Gleichzeitig ist der Dialekt für die eigene Identität wichtig.\",","    \"lektion\": 2,","    \"audio\": \"120.opus\",","    \"teil\": 7","  },","  {","    \"id\": 121,","    \"wort\": \"bei\",","    \"grammatik\": \"+ Dativ\",","    \"beispiel\": \"Er erklärt, was beim Deutschlernen helfen kann.\",","    \"lektion\": 2,","    \"audio\": \"121.opus\",","    \"teil\": 8","  },","  {","    \"id\": 122,","    \"wort\": \"hauptsächlich\",","    \"grammatik\": \"\",","    \"beispiel\": \"Welche Fremdsprachen werden in deinem Land hauptsächlich gelernt?\",","    \"lektion\": 2,","    \"audio\": \"122.opus\",","    \"teil\": 8","  },","  {","    \"id\": 123,","    \"wort\": \"Bedeutung\",","    \"grammatik\": \"die, Bedeutungen\",","    \"beispiel\": \"Welche Bedeutung haben Fremdsprachen heute?\",","    \"lektion\": 2,","    \"audio\": \"123.opus\",","    \"teil\": 8","  },","  {","    \"id\": 124,","    \"wort\": \"beginnen\",","    \"grammatik\": \"beginnt, begann, hat begonnen\",","    \"beispiel\": \"Ich frage mich, wann man beginnen sollte, eine Fremdsprache zu lernen.\",","    \"lektion\": 2,","    \"audio\": \"124.opus\",","    \"teil\": 8","  },","  {","    \"id\": 125,","    \"wort\": \"auffallen\",","    \"grammatik\": \"an + Dativ\",","    \"beispiel\": \"Was fällt dir an der Grafik besonders auf?\",","    \"lektion\": 2,","    \"audio\": \"125.opus\",","    \"teil\": 8","  },","  {","    \"id\": 126,","    \"wort\": \"gehören\",","    \"grammatik\": \"zu + Dativ\",","    \"beispiel\": \"Obwohl die Band ausschliesslich auf Bairisch singt, gehört sie heute zu den populärsten Bands Deutschlands.\",","    \"lektion\": 2,","    \"audio\": \"126.opus\",","    \"teil\": 8","  },","  {","    \"id\": 127,","    \"wort\": \"Körpergefühl\",","    \"grammatik\": \"das\",","    \"beispiel\": \"Der Bandleader erzählt von sich, bei seinen Ansagen auf Hochdeutsch habe er ein schlechtes Körpergefühl.\",","    \"lektion\": 2,","    \"audio\": \"127.opus\",","    \"teil\": 8","  },","  {","    \"id\": 128,","    \"wort\": \"Rolle\",","    \"grammatik\": \"die, Rollen\",","    \"beispiel\": \"Im Schweizer Mundartrock spielt Berndeutsch eine besondere Rolle.\",","    \"lektion\": 2,","    \"audio\": \"128.opus\",","    \"teil\": 8","  },","  {","    \"id\": 129,","    \"wort\": \"Lücke\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Wessen Lebenslauf Lücken aufweist, der fürchtet sich vielleicht vor einem Bewerbungsgespräch.\",","    \"lektion\": 3,","    \"audio\": \"129.opus\",","    \"teil\": 1","  },","  {","    \"id\": 130,","    \"wort\": \"vollziehen\",","    \"grammatik\": \"vollzieht, vollzog, hat vollzogen\",","    \"beispiel\": \"Wer in seiner Ausbildung Richtungswechsel vollzogen hat, hat sicher Erkenntnisse gewonnen.\",","    \"lektion\": 3,","    \"audio\": \"130.opus\",","    \"teil\": 1","  },","  {","    \"id\": 131,","    \"wort\": \"revidieren\",","    \"grammatik\": \"revidiert, revidierte, hat revidiert\",","    \"beispiel\": \"Wenn man eine falsche Entscheidung trifft, kann man diese revidieren.\",","    \"lektion\": 3,","    \"audio\": \"131.opus\",","    \"teil\": 1","  },","  {","    \"id\": 132,","    \"wort\": \"stören\",","    \"grammatik\": \"stört, störte, hat gestört\",","    \"beispiel\": \"Personalchefs stört ein Berufs- oder Studienwechsel in der Regel nicht so sehr.\",","    \"lektion\": 3,","    \"audio\": \"132.opus\",","    \"teil\": 1","  },","  {","    \"id\": 133,","    \"wort\": \"Wahl\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Die Wahl eines passenden Berufs ist sehr wichtig.\",","    \"lektion\": 3,","    \"audio\": \"133.opus\",","    \"teil\": 1","  },","  {","    \"id\": 134,","    \"wort\": \"Ehrlichkeit\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Personalchefs fordern Ehrlichkeit bei der Erläuterung von Lücken und Richtungswechseln.\",","    \"lektion\": 3,","    \"audio\": \"134.opus\",","    \"teil\": 1","  },","  {","    \"id\": 135,","    \"wort\": \"Infinitivsatz\",","    \"grammatik\": \"gleiches Subjekt\",","    \"beispiel\": \"Viele Bewerber fürchten, vom Personalchef kritisiert zu werden.\",","    \"lektion\": 3,","    \"audio\": \"135.opus\",","    \"teil\": 1","  },","  {","    \"id\": 136,","    \"wort\": \"Akkusativobjekt\",","    \"grammatik\": \"zwei verschiedene Subjekte\",","    \"beispiel\": \"Bewerber fürchten, dass der Personalchef ihren Berufswechsel kritisiert.\",","    \"lektion\": 3,","    \"audio\": \"136.opus\",","    \"teil\": 1","  },","  {","    \"id\": 137,","    \"wort\": \"Lebenslauf\",","    \"grammatik\": \"der\",","    \"beispiel\": \"Ein Lebenslauf, der nur aus einer zeitlichen Aufzählung von Daten besteht, ist langweilig.\",","    \"lektion\": 3,","    \"audio\": \"137.opus\",","    \"teil\": 2","  },","  {","    \"id\": 138,","    \"wort\": \"damals\",","    \"grammatik\": \"\",","    \"beispiel\": \"Was hat sich heute im Vergleich zu damals verändert?\",","    \"lektion\": 3,","    \"audio\": \"138.opus\",","    \"teil\": 2","  },","  {","    \"id\": 139,","    \"wort\": \"sich inszenieren\",","    \"grammatik\": \"inszeniert sich, inszenierte sich, hat sich inszeniert\",","    \"beispiel\": \"Der grösste Unterschied ist, dass man sich heute viel stärker inszenieren muss.\",","    \"lektion\": 3,","    \"audio\": \"139.opus\",","    \"teil\": 2","  },","  {","    \"id\": 140,","    \"wort\": \"Angebot\",","    \"grammatik\": \"das, Angebote\",","    \"beispiel\": \"Es gibt ein grosses Angebot an Ratgebern zum Thema «Bewerbung».\",","    \"lektion\": 3,","    \"audio\": \"140.opus\",","    \"teil\": 2","  },","  {","    \"id\": 141,","    \"wort\": \"unvorbereitet\",","    \"grammatik\": \"\",","    \"beispiel\": \"Viel Bewerber gehen relativ unvorbereitet an die Sache heran.\",","    \"lektion\": 3,","    \"audio\": \"141.opus\",","    \"teil\": 2","  },","  {","    \"id\": 142,","    \"wort\": \"Schwäche\",","    \"grammatik\": \"die, Schwächen\",","    \"beispiel\": \"Worin sehen Sie die grösste Schwäche der Bewerber?\",","    \"lektion\": 3,","    \"audio\": \"142.opus\",","    \"teil\": 2","  },","  {","    \"id\": 143,","    \"wort\": \"Ware\",","    \"grammatik\": \"die, Waren\",","    \"beispiel\": \"Wer sich bewirbt, bietet eine Ware an, nämlich seine Kenntnisse und sein Wissen.\",","    \"lektion\": 3,","    \"audio\": \"143.opus\",","    \"teil\": 2","  },","  {","    \"id\": 144,","    \"wort\": \"sich verhalten\",","    \"grammatik\": \"verhält sich, verhielt sich, hat sich verhalten\",","    \"beispiel\": \"Der Personalchef interessiert sich auch dafür, wie Sie sich in schwierigen Situationen verhalten.\",","    \"lektion\": 3,","    \"audio\": \"144.opus\",","    \"teil\": 2","  },","  {","    \"id\": 145,","    \"wort\": \"voraussetzen\",","    \"grammatik\": \"setzt voraus, setzte voraus, hat vorausgesetzt\",","    \"beispiel\": \"Für bestimmte berufliche Positionen wird häufig ein Hochschulstudium vorausgesetzt.\",","    \"lektion\": 3,","    \"audio\": \"145.opus\",","    \"teil\": 3","  },","  {","    \"id\": 146,","    \"wort\": \"gesellschaftlich\",","    \"grammatik\": \"\",","    \"beispiel\": \"Ein akademischer Titel hat gesellschaftlich einen hohen Stellenwert.\",","    \"lektion\": 3,","    \"audio\": \"146.opus\",","    \"teil\": 3","  },","  {","    \"id\": 147,","    \"wort\": \"abhängen\",","    \"grammatik\": \"von + Dativ\\nhängt ab, hing ab, hat (ist) abgehangen\",","    \"beispiel\": \"Heute hängt die berufliche Sicherheit von vielen Faktoren ab.\",","    \"lektion\": 3,","    \"audio\": \"147.opus\",","    \"teil\": 3","  },","  {","    \"id\": 148,","    \"wort\": \"verbinden\",","    \"grammatik\": \"mit + Dativ\\nverbindet, verband, hat verbunden\",","    \"beispiel\": \"Ein berufsbegleitendes Studium verbindet wissenschaftliche Theorie mit beruflicher Praxis.\",","    \"lektion\": 3,","    \"audio\": \"148.opus\",","    \"teil\": 3","  },","  {","    \"id\": 149,","    \"wort\": \"fest\",","    \"grammatik\": \"\",","    \"beispiel\": \"Ich war jahrelang in einem festen Arbeitsverhältnis.\",","    \"lektion\": 3,","    \"audio\": \"149.opus\",","    \"teil\": 3","  },","  {","    \"id\": 150,","    \"wort\": \"kündigen\",","    \"grammatik\": \"kündigt, kündigte, hat gekündigt\",","    \"beispiel\": \"Wegen einer Umstrukturierung aus betrieblichen Gründen wurde mir gekündigt.\",","    \"lektion\": 3,","    \"audio\": \"150.opus\",","    \"teil\": 3","  },","  {","    \"id\": 151,","    \"wort\": \"Bescheid\",","    \"grammatik\": \"der\",","    \"beispiel\": \"Vor einer Woche habe ich einen positiven Bescheid bekommen.\",","    \"lektion\": 3,","    \"audio\": \"151.opus\",","    \"teil\": 3","  },","  {","    \"id\": 152,","    \"wort\": \"eingehen\",","    \"grammatik\": \"auf + Akkusativ\\ngeht ein, ging ein, ist eingegangen\",","    \"beispiel\": \"Sogar auf meine Gehaltsvorstellungen wurde eingegangen.\",","    \"lektion\": 3,","    \"audio\": \"152.opus\",","    \"teil\": 3","  },","  {","    \"id\": 153,","    \"wort\": \"Nachteil\",","    \"grammatik\": \"der, Erörterung\",","    \"beispiel\": \"Es ist ein grosser Nachteil, wenn man während der Ausbildung finanziell von seinen Eltern abhängig ist.\",","    \"lektion\": 3,","    \"audio\": \"153.opus\",","    \"teil\": 4","  },","  {","    \"id\": 154,","    \"wort\": \"Tatsache\",","    \"grammatik\": \"die, Erörterung\",","    \"beispiel\": \"Die Tatsache, dass man während des Studiums arbeitet, spricht für dieses Modell.\",","    \"lektion\": 3,","    \"audio\": \"154.opus\",","    \"teil\": 4","  },","  {","    \"id\": 155,","    \"wort\": \"überwiegen\",","    \"grammatik\": \"überwiegt, überwog, hat überwogen\\nErörterung\",","    \"beispiel\": \"In meinen Augen überwiegen die Nachteile eines berufsbegleitenden Studiums.\",","    \"lektion\": 3,","    \"audio\": \"155.opus\",","    \"teil\": 4","  },","  {","    \"id\": 156,","    \"wort\": \"betrachten\",","    \"grammatik\": \"betrachtet, betrachtete, hat betrachtet\\nErörterung\",","    \"beispiel\": \"Betrachtet man alle Argumente, fallen am meisten die besseren Berufsaussichten ins Gewicht.\",","    \"lektion\": 3,","    \"audio\": \"156.opus\",","    \"teil\": 4","  },","  {","    \"id\": 157,","    \"wort\": \"sich wenden\",","    \"grammatik\": \"an + Akkusativ\",","    \"beispiel\": \"An wen kann ich mich während meiner Ausbildung mit Frage wenden?\",","    \"lektion\": 3,","    \"audio\": \"157.opus\",","    \"teil\": 4","  },","  {","    \"id\": 158,","    \"wort\": \"Erstattung\",","    \"grammatik\": \"die, von + Dativ\",","    \"beispiel\": \"Eine Erstattung von Fahrtkosten erfolgt nicht.\",","    \"lektion\": 3,","    \"audio\": \"158.opus\",","    \"teil\": 4","  },","  {","    \"id\": 159,","    \"wort\": \"Verhinderung\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Bei krankheitsbedingter Verhinderung ist innerhalb von drei Tagen ein ärztliches Zeugnis vorzulegen.\",","    \"lektion\": 3,","    \"audio\": \"159.opus\",","    \"teil\": 4","  },","  {","    \"id\": 160,","    \"wort\": \"fällig\",","    \"grammatik\": \"\",","    \"beispiel\": \"Die Vergütung wird jeweils auf Ende des Monats fällig.\",","    \"lektion\": 3,","    \"audio\": \"160.opus\",","    \"teil\": 4","  },","  {","    \"id\": 161,","    \"wort\": \"ablenken\",","    \"grammatik\": \"lenkt ab, lenkte ab, hat abgelenkt\",","    \"beispiel\": \"Wer während des Autofahrens telefoniert, ist in jedem Fall abgelenkt.\",","    \"lektion\": 3,","    \"audio\": \"161.opus\",","    \"teil\": 5","  },","  {","    \"id\": 162,","    \"wort\": \"führen\",","    \"grammatik\": \"zu\",","    \"beispiel\": \"Telefonieren beim Autofahren führt zu einem viermal so hohen Unfallrisiko.\",","    \"lektion\": 3,","    \"audio\": \"162.opus\",","    \"teil\": 5","  },","  {","    \"id\": 163,","    \"wort\": \"Doppelbelastung\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Das Gehirn ist einer Doppelbelastung nicht gewachsen.\",","    \"lektion\": 3,","    \"audio\": \"163.opus\",","    \"teil\": 5","  },","  {","    \"id\": 164,","    \"wort\": \"Multitasking\",","    \"grammatik\": \"der\",","    \"beispiel\": \"Multitasking ist ein schneller Wechsel zwischen verschiedenen Aufgaben.\",","    \"lektion\": 3,","    \"audio\": \"164.opus\",","    \"teil\": 5","  },","  {","    \"id\": 165,","    \"wort\": \"weshalb\",","    \"grammatik\": \"weiterführender Nebensatz\",","    \"beispiel\": \"Viele stehen unter Zeitdruck, weshalb sie es mit Multitasking versuchen.\",","    \"lektion\": 3,","    \"audio\": \"165.opus\",","    \"teil\": 5","  },","  {","    \"id\": 166,","    \"wort\": \"was\",","    \"grammatik\": \"weiterführender Nebensatz\",","    \"beispiel\": \"Er versuchte mehreres gleichzeitig zu erledigen, was ihn aber nicht weiterbrachte.\",","    \"lektion\": 3,","    \"audio\": \"166.opus\",","    \"teil\": 5","  },","  {","    \"id\": 167,","    \"wort\": \"wodurch\",","    \"grammatik\": \"weiterführender Nebensatz\",","    \"beispiel\": \"Man sollte ohne Unterbrechungen durcharbeiten können, wodurch man viele Kräfte sparen würde.\",","    \"lektion\": 3,","    \"audio\": \"167.opus\",","    \"teil\": 5","  },","  {","    \"id\": 168,","    \"wort\": \"worin\",","    \"grammatik\": \"weiterführender Nebensatz\",","    \"beispiel\": \"Beim Multitasking erledigt man zumindest eine der Aufgaben höchstens mit halber Kraft, worin der Preis für das Multitasking besteht.\",","    \"lektion\": 3,","    \"audio\": \"168.opus\",","    \"teil\": 5","  },","  {","    \"id\": 169,","    \"wort\": \"Ellenbogen\",","    \"grammatik\": \"der\",","    \"beispiel\": \"Ellenbogentypen, die nur den persönlichen Erfolg im Auge haben, sind heute nicht mehr gefragt.\",","    \"lektion\": 3,","    \"audio\": \"169.opus\",","    \"teil\": 6","  },","  {","    \"id\": 170,","    \"wort\": \"Softskills\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Wegen der Veränderungen in der Arbeitswelt werden Softskills heute als wichtiger betrachtet.\",","    \"lektion\": 3,","    \"audio\": \"170.opus\",","    \"teil\": 6","  },","  {","    \"id\": 171,","    \"wort\": \"Bereitschaft\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Da der technologische Fortschritt rasant ist, wird Veränderungsbereitschaft gefordert.\",","    \"lektion\": 3,","    \"audio\": \"171.opus\",","    \"teil\": 6","  },","  {","    \"id\": 172,","    \"wort\": \"Ball\",","    \"grammatik\": \"der, Bälle / am Ball bleiben\",","    \"beispiel\": \"Um am Ball zu bleiben, muss man sich ständig weiterentwickeln.\",","    \"lektion\": 3,","    \"audio\": \"172.opus\",","    \"teil\": 6","  },","  {","    \"id\": 173,","    \"wort\": \"interkulturell\",","    \"grammatik\": \"\",","    \"beispiel\": \"Interkulturelle Kompetenz verdankt ihre Beliebtheit der Globalisierung.\",","    \"lektion\": 3,","    \"audio\": \"173.opus\",","    \"teil\": 6","  },","  {","    \"id\": 174,","    \"wort\": \"Zusammenhang\",","    \"grammatik\": \"der, Zusammenhänge\",","    \"beispiel\": \"Vernetztes Denken bedeutet, auch komplexe Zusammenhänge zu überblicken.\",","    \"lektion\": 3,","    \"audio\": \"174.opus\",","    \"teil\": 6","  },","  {","    \"id\": 175,","    \"wort\": \"interpretieren\",","    \"grammatik\": \"interpretiert, interpretierte, hat interpretiert\",","    \"beispiel\": \"Wie Belastbarkeit zu interpretieren ist, im persönlichen Bewerbungsgespräch zu klären.\",","    \"lektion\": 3,","    \"audio\": \"175.opus\",","    \"teil\": 6","  },","  {","    \"id\": 176,","    \"wort\": \"gelassen\",","    \"grammatik\": \"\",","    \"beispiel\": \"Wer belastbar ist, bleibt auch in hektischen Zeiten gelassen.\",","    \"lektion\": 3,","    \"audio\": \"176.opus\",","    \"teil\": 6","  },","  {","    \"id\": 177,","    \"wort\": \"sich befassen\",","    \"grammatik\": \"mit Dativ\\nbefasst, befasste, hat befasst\",","    \"beispiel\": \"In meinem Vortrag befasse ich mich mit dem Thema «Kinder und soziale Medien».\",","    \"lektion\": 3,","    \"audio\": \"177.opus\",","    \"teil\": 7","  },","  {","    \"id\": 178,","    \"wort\": \"Erfahrung\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Meine eigenen Erfahrungen haben mir gezeigt, dass in den sozialen Medien oft die Kontrolle über die Zeit verloren geht.\",","    \"lektion\": 3,","    \"audio\": \"178.opus\",","    \"teil\": 7","  },","  {","    \"id\": 179,","    \"wort\": \"treffend\",","    \"grammatik\": \"\",","    \"beispiel\": \"Ein treffendes Beispiel für die Gefahren sozialer Medien sind die bekannten Mobbingfälle in Sekundarschulen.\",","    \"lektion\": 3,","    \"audio\": \"179.opus\",","    \"teil\": 7","  },","  {","    \"id\": 180,","    \"wort\": \"Aschreiben\",","    \"grammatik\": \"\",","    \"beispiel\": \"Im Anschreiben stellt der Bewerber seinen Lebenslauf und seine Fähigkeiten in Bezug auf die ausgeschriebene Stelle vor.\",","    \"lektion\": 3,","    \"audio\": \"180.opus\",","    \"teil\": 7","  },","  {","    \"id\": 181,","    \"wort\": \"beschreiben\",","    \"grammatik\": \"beschreibt, beschrieb, hat beschrieben\",","    \"beispiel\": \"In einem Anschreiben beschreibt man bespielhafte Situationen, in denen man seine Softskills schon eingesetzt hat.\",","    \"lektion\": 3,","    \"audio\": \"181.opus\",","    \"teil\": 7","  },","  {","    \"id\": 182,","    \"wort\": \"bewerten\",","    \"grammatik\": \"bewertet, bewertete, hat bewertet\",","    \"beispiel\": \"Bei einem Assessment Center werden Beobachter eingesetzt, die das Verhalten des Bewerbers bewerten.\",","    \"lektion\": 3,","    \"audio\": \"182.opus\",","    \"teil\": 7","  },","  {","    \"id\": 183,","    \"wort\": \"Innovativ\",","    \"grammatik\": \"\",","    \"beispiel\": \"Ein innovativer Charakter soll neuen Wind in ein eingespieltes Team bringen.\",","    \"lektion\": 3,","    \"audio\": \"183.opus\",","    \"teil\": 7","  },","  {","    \"id\": 184,","    \"wort\": \"fortan\",","    \"grammatik\": \"\",","    \"beispiel\": \"In Bewerbungsverfahren kann man lernen, fortan besser mit seinen Stärken und Schwächen umzugehen.\",","    \"lektion\": 3,","    \"audio\": \"184.opus\",","    \"teil\": 7","  },","  {","    \"id\": 185,","    \"wort\": \"Handarbeit\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Zwei junge Männer gründeten ein erfolgreiches Handarbeitsunternehmen, das mittlerweile ca. 40 häkelnde Rentnerinnen beschäftigt.\",","    \"lektion\": 3,","    \"audio\": \"185.opus\",","    \"teil\": 8","  },","  {","    \"id\": 186,","    \"wort\": \"Anleitung\",","    \"grammatik\": \"die, Anleitungen\",","    \"beispiel\": \"Auf einem Youtube-Kanal werden genaue Anleitungen für Fussballtricks gezeigt.\",","    \"lektion\": 3,","    \"audio\": \"186.opus\",","    \"teil\": 8","  },","  {","    \"id\": 187,","    \"wort\": \"sich erkundigen\",","    \"grammatik\": \"erkundigt sich, erkundigte sich, hat sich erkundigt\",","    \"beispiel\": \"Eine angehende Studentin erkundigte sich nach den Zulassungsvoraussetzungen.\",","    \"lektion\": 3,","    \"audio\": \"187.opus\",","    \"teil\": 8","  },","  {","    \"id\": 188,","    \"wort\": \"dauern\",","    \"grammatik\": \"dauert, dauerte, hat gedauert\",","    \"beispiel\": \"Das kaufmännische Praktikum soll mindestens zwölf Wochen dauern.\",","    \"lektion\": 3,","    \"audio\": \"188.opus\",","    \"teil\": 8","  },","  {","    \"id\": 189,","    \"wort\": \"Frist\",","    \"grammatik\": \"die, Fristen\",","    \"beispiel\": \"Welche Bewerbungsfristen gelten, um die Unterlagen einzuschicken?\",","    \"lektion\": 3,","    \"audio\": \"189.opus\",","    \"teil\": 8","  },","  {","    \"id\": 190,","    \"wort\": \"Kriterium\",","    \"grammatik\": \"das, Kriterien\",","    \"beispiel\": \"Die Bewerber werden nach bestimmten Kriterien ausgewählt.\",","    \"lektion\": 3,","    \"audio\": \"190.opus\",","    \"teil\": 8","  },","  {","    \"id\": 191,","    \"wort\": \"Bescheid\",","    \"grammatik\": \"der\",","    \"beispiel\": \"Man erhält auf jeden Fall schriftlichen Bescheid.\",","    \"lektion\": 3,","    \"audio\": \"191.opus\",","    \"teil\": 8","  },","  {","    \"id\": 192,","    \"wort\": \"Argument\",","    \"grammatik\": \"das, Argumente\",","    \"beispiel\": \"Welche Argumente sprechen für feste Arbeitszeiten?\",","    \"lektion\": 3,","    \"audio\": \"192.opus\",","    \"teil\": 8","  },","  {","    \"id\": 193,","    \"wort\": \"Umsatz\",","    \"grammatik\": \"der\",","    \"beispiel\": \"Der Umsatz, auch Erlös genannt, ist der Gesamtwert aller verkauften Waren eines Unternehmens über einen bestimmten Zeitraum.\",","    \"lektion\": 4,","    \"audio\": \"193.opus\",","    \"teil\": 1","  },","  {","    \"id\": 194,","    \"wort\": \"Aktie\",","    \"grammatik\": \"die, Aktien\",","    \"beispiel\": \"Eine Aktie ist ein Wertpapier, das einem einen Anteil an einer Aktiengesellschaft bestätigt.\",","    \"lektion\": 4,","    \"audio\": \"194.opus\",","    \"teil\": 1","  },","  {","    \"id\": 195,","    \"wort\": \"Inflation\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Wenn sich allgemein die Preise für Güter erhöhen und damit Ersparnisse an Wert verlieren, spricht man von Inflation.\",","    \"lektion\": 4,","    \"audio\": \"195.opus\",","    \"teil\": 1","  },","  {","    \"id\": 196,","    \"wort\": \"Währung\",","    \"grammatik\": \"die, Währungen\",","    \"beispiel\": \"Bei der Währung handelt es sich um das gesetzliche Zahlungsmittel eines Landes.\",","    \"lektion\": 4,","    \"audio\": \"196.opus\",","    \"teil\": 1","  },","  {","    \"id\": 197,","    \"wort\": \"Ökonomie\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Die Ökonomie befasst sich mit der Produktion, der Verteilung und dem Konsum von Gütern und Dienstleistungen.\",","    \"lektion\": 4,","    \"audio\": \"197.opus\",","    \"teil\": 1","  },","  {","    \"id\": 198,","    \"wort\": \"Devisen\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Devisen sind Zahlungsmittel in ausländischer Währung.\",","    \"lektion\": 4,","    \"audio\": \"198.opus\",","    \"teil\": 1","  },","  {","    \"id\": 199,","    \"wort\": \"Bonität\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Banken gewähren Kunden Kredite, wenn deren Bonität/Zahlungsfähigkeit als genügend eingeschätzt wird.\",","    \"lektion\": 4,","    \"audio\": \"199.opus\",","    \"teil\": 1","  },","  {","    \"id\": 200,","    \"wort\": \"erschrecken\",","    \"grammatik\": \"über + Akkusativ erschrickt, erschrak, ist erschrocken\",","    \"beispiel\": \"Als der Hirtenjunge in die Asche greifen wollte, erschrak er über die rotglühenden Steine.\",","    \"lektion\": 4,","    \"audio\": \"200.opus\",","    \"teil\": 1","  },","  {","    \"id\": 201,","    \"wort\": \"Steinkohle\",","    \"grammatik\": \"die\",","    \"beispiel\": \"Abgestorbene Pflanzen werden zuerst in Torf und dann in Braun- oder Steinkohle verwandelt.\",","    \"lektion\": 4,","    \"audio\": \"201.opus\",","    \"teil\": 2","  },","  {","    \"id\": 202,","    \"wort\": \"drastisch\",","    \"grammatik\": \"\",","    \"beispiel\": \"Nach dem Zweiten Weltkrieg veränderte sich die Trümmerlandschaft des Ruhrgebiets drastisch.\",","    \"lektion\": 4,","    \"audio\": \"202.opus\",","    \"teil\": 2","  },","  {","    \"id\": 203,","    \"wort\": \"Bergbau\",","    \"grammatik\": \"der\",","    \"beispiel\": \"Es gab viele Arbeitsplätze im Bergbau, der in dieser Zeit seinen Höhepunkt erreichte.\",","    \"lektion\": 4,","    \"audio\": \"203.opus\",","    \"teil\": 2","  },","  {","    \"id\": 204,","    \"wort\": \"Aushängeschild\",","    \"grammatik\": \"das\",","    \"beispiel\": \"Das Ruhrgebiet der Nachkriegszeit war das Aushängeschild der deutschen Wirtschaft.\",","    \"lektion\": 4,","    \"audio\": \"204.opus\",","    \"teil\": 2","  },","  {","    \"id\": 205,","    \"wort\": \"Stahl\",","    \"grammatik\": \"der\",","    \"beispiel\": \"Seine Kohle und sein Stahl waren der Motor des Wirtschaftswunders.\",","    \"lektion\": 4,","    \"audio\": \"205.opus\",","    \"teil\": 2","  },","  {","    \"id\": 206,","    \"wort\": \"Krise\",","    \"grammatik\": \"die, Krisen\",","    \"beispiel\": \"Die Kohlekrise begann damit, dass Kohle durch Öl und Erdgas ersetzt wurde.\",","    \"lektion\": 4,","    \"audio\": \"206.opus\",","    \"teil\": 2","  },","  {","    \"id\": 207,","    \"wort\": \"umstellen\",","    \"grammatik\": \"auf + Akkusativ, stellt um, stellte um, hat umgestellt\",","    \"beispiel\": \"Die Deutsche Bundesbahn stellte ihre Züge auf elektrischen Betrieb um.\",","    \"lektion\": 4,","    \"audio\": \"207.opus\",","    \"teil\": 2","  },","  {","    \"id\": 208,","    \"wort\": \"dicht\",","    \"grammatik\": \"\",","    \"beispiel\": \"Das Ruhrgebiet wurde zur dichtesten Hochschullandschaft Europas.\",","    \"lektion\": 4,","    \"audio\": \"208.opus\",","    \"teil\": 2","  },","  {","    \"id\": 209,","    \"wort\": \"seit/seitdem\",","    \"grammatik\": \"Nominal-/Verbform\",","    \"beispiel\": \"seit Beginn des Kurses/seitdem der Kurs begann\",","    \"lektion\": 4,","    \"audio\": \"209.opus\",","    \"teil\": 3","  },","  {","    \"id\": 210,","    \"wort\": \"nach/nachdem\",","    \"grammatik\": \"Nominal-/Verbform\",","    \"beispiel\": \"nach Beendigung der Arbeit/nachdem die Arbeit beendet wurde/beendet worden war\",","    \"lektion\": 4,","    \"audio\": \"210.opus\",","    \"teil\": 3","  },","  {","    \"id\": 211,","    \"wort\": \"bei/als\",","    \"grammatik\": \"Nominal-/Verbform\",","    \"beispiel\": \"bei der Wahl zum Präsidenten/als man ihn zum Präsidenten wählte\",","    \"lektion\": 4,","    \"audio\": \"211.opus\",","    \"teil\": 3","  },","  {","    \"id\": 212,","    \"wort\": \"bis zu/bis\",","    \"grammatik\": \"Nominal-/Verbform\",","    \"beispiel\": \"bis zu ihrer Pensionierung/bis sie pensioniert wurde\","," 