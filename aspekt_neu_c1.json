\"վնասել\",","    \"chinesisch\": \"伤害\",","    \"farsi\": \"آسیب رساندن\",","    \"kurdisch\": \"birîndar kirin\",","    \"ukrainisch\": \"поранити\",","    \"beispiel\": \"Durch sein rücksichtsloses Verhalten im Straßenverkehr könnte er andere Teilnehmer schwer verletzen.\",","    \"kapitel\": 7","  },","  {","    \"id\": 554,","    \"deutsch\": \"verhaften\",","    \"turkisch\": \"tutuklamak\",","    \"armenisch\": \"ձերբակալել\",","    \"chinesisch\": \"逮捕\",","    \"farsi\": \"دستگیر کردن\",","    \"kurdisch\": \"girtin\",","    \"ukrainisch\": \"заарештовувати\",","    \"beispiel\": \"Die Polizei konnte den mutmaßlichen Drahtzieher des Betrugs am Flughafen verhaften.\",","    \"kapitel\": 7","  },","  {","    \"id\": 555,","    \"deutsch\": \"verurteilen\",","    \"turkisch\": \"mahkum etmek\",","    \"armenisch\": \"դատապարտել\",","    \"chinesisch\": \"判刑\",","    \"farsi\": \"محکوم کردن\",","    \"kurdisch\": \"mehkûm kirin\",","    \"ukrainisch\": \"засуджувати\",","    \"beispiel\": \"Das Gericht entschied, den jungen Mann wegen Diebstahls zu einer Bewährungsstrafe zu verurteilen.\",","    \"kapitel\": 7","  },","  {","    \"id\": 556,","    \"deutsch\": \"verteidigen\",","    \"turkisch\": \"savunmak\",","    \"armenisch\": \"պաշտպանել\",","    \"chinesisch\": \"辩护\",","    \"farsi\": \"دفاع کردن\",","    \"kurdisch\": \"parastin\",","    \"ukrainisch\": \"захищати\",","    \"beispiel\": \"Ein Pflichtverteidiger hat die Aufgabe, die Rechte seines Mandanten vor Gericht zu verteidigen.\",","    \"kapitel\": 7","  },","  {","    \"id\": 557,","    \"deutsch\": \"verklagen\",","    \"turkisch\": \"dava etmek\",","    \"armenisch\": \"դատի տալ\",","    \"chinesisch\": \"起诉\",","    \"farsi\": \"شکایت کردن\",","    \"kurdisch\": \"doz vekirin\",","    \"ukrainisch\": \"подавати в суд\",","    \"beispiel\": \"Die Firma entschied sich dazu, ihren ehemaligen Partner wegen Vertragsbruchs zu verklagen.\",","    \"kapitel\": 7","  },","  {","    \"id\": 558,","    \"deutsch\": \"vollstrecken\",","    \"turkisch\": \"infaz etmek\",","    \"armenisch\": \"ի կատար ածել\",","    \"chinesisch\": \"执行\",","    \"farsi\": \"اجرا کردن\",","    \"kurdisch\": \"pêk anîn\",","    \"ukrainisch\": \"виконувати\",","    \"beispiel\": \"Die zuständige Behörde muss das rechtskräftige Urteil nun zeitnah vollstrecken.\",","    \"kapitel\": 7","  },","  {","    \"id\": 559,","    \"deutsch\": \"diebstahlsicher\",","    \"turkisch\": \"hırsızlığa karşı güvenli\",","    \"armenisch\": \"գողությունից պաշտպանված\",","    \"chinesisch\": \"防盗的\",","    \"farsi\": \"ضد سرقت\",","    \"kurdisch\": \"dijî-diziyê\",","    \"ukrainisch\": \"захищений від крадіжки\",","    \"beispiel\": \"Das neue Sicherheitsschloss macht die Eingangstür fast absolut diebstahlsicher.\",","    \"kapitel\": 7","  },","  {","    \"id\": 560,","    \"deutsch\": \"rechtskräftig\",","    \"turkisch\": \"yasal olarak geçerli\",","    \"armenisch\": \"օրինական ուժի մեջ մտած\",","    \"chinesisch\": \"具有法律效力的\",","    \"farsi\": \"لازم الاجرا\",","    \"kurdisch\": \"bi qanûnî derbasdar\",","    \"ukrainisch\": \"такий, що набрав законної сили\",","    \"beispiel\": \"Erst wenn ein Urteil rechtskräftig ist, kann die Strafe offiziell vollzogen werden.\",","    \"kapitel\": 7","  },","  {","    \"id\": 561,","    \"deutsch\": \"strafbar\",","    \"turkisch\": \"cezalandırılabilir\",","    \"armenisch\": \"պատժելի\",","    \"chinesisch\": \"应受惩罚的\",","    \"farsi\": \"قابل مجازات\",","    \"kurdisch\": \"ceza\",","    \"ukrainisch\": \"карний\",","    \"beispiel\": \"Bestimmte Handlungen im Internet, wie das Herunterladen von Raubkopien, sind strafbar.\",","    \"kapitel\": 7","  },","  {","    \"id\": 562,","    \"deutsch\": \"schuldig\",","    \"turkisch\": \"suçlu\",","    \"armenisch\": \"մեղավոր\",","    \"chinesisch\": \"有罪的\",","    \"farsi\": \"گناهکار\",","    \"kurdisch\": \"sûcdar\",","    \"ukrainisch\": \"винний\",","    \"beispiel\": \"Der Angeklagte wurde in allen Punkten der Anklage für schuldig befunden.\",","    \"kapitel\": 7","  },","  {","    \"id\": 563,","    \"deutsch\": \"unschuldig\",","    \"turkisch\": \"masum\",","    \"armenisch\": \"անմեղ\",","    \"chinesisch\": \"无辜的\",","    \"farsi\": \"بی گناه\",","    \"kurdisch\": \"bêsûc\",","    \"ukrainisch\": \"невинний\",","    \"beispiel\": \"Obwohl alle Beweise gegen ihn sprachen, beteuerte er bis zum Schluss seine unschuldig.\",","    \"kapitel\": 7","  },","  {","    \"id\": 564,","    \"deutsch\": \"die Zivilcourage (Sg.)\",","    \"turkisch\": \"medeni cesaret\",","    \"armenisch\": \"քաղաքացիական արիություն\",","    \"chinesisch\": \"公民勇气\",","    \"farsi\": \"شجاعت مدنی\",","    \"kurdisch\": \"wêrekiya sivîl\",","    \"ukrainisch\": \"громадянська мужність\",","    \"beispiel\": \"Es erfordert viel Zivilcourage, einzugreifen, wenn man sieht, dass jemand in der U-Bahn bedrängt wird.\",","    \"kapitel\": 7","  },","  {","    \"id\": 565,","    \"deutsch\": \"die Selbstjustiz (Sg.)\",","    \"turkisch\": \"kendi adaletini sağlama\",","    \"armenisch\": \"ինքնադատաստան\",","    \"chinesisch\": \"私自执法\",","    \"farsi\": \"عدالت شخصی\",","    \"kurdisch\": \"xwedadwerî\",","    \"ukrainisch\": \"самосуд\",","    \"beispiel\": \"In einem Rechtsstaat ist Selbstjustiz streng verboten, da das Gewaltmonopol beim Staat liegt.\",","    \"kapitel\": 7","  },","  {","    \"id\": 566,","    \"deutsch\": \"die Notwehr (Sg.)\",","    \"turkisch\": \"meşru müdafaa\",","    \"armenisch\": \"անհրաժեշտ պաշտպանություն\",","    \"chinesisch\": \"正当防卫\",","    \"farsi\": \"دفاع مشروع\",","    \"kurdisch\": \"xweparastina rewa\",","    \"ukrainisch\": \"необхідна оборона\",","    \"beispiel\": \"Er handelte in Notwehr, als er versuchte, sich gegen den bewaffneten Angreifer zu wehren.\",","    \"kapitel\": 7","  },","  {","    \"id\": 567,","    \"deutsch\": \"das Gewissen, -\",","    \"turkisch\": \"vicdan\",","    \"armenisch\": \"խիղճ\",","    \"chinesisch\": \"良心\",","    \"farsi\": \"وجدان\",","    \"kurdisch\": \"wijdan\",","    \"ukrainisch\": \"совість\",","    \"beispiel\": \"Man sollte immer so handeln, dass man es mit seinem eigenen Gewissen vereinbaren kann.\",","    \"kapitel\": 7","  },","  {","    \"id\": 568,","    \"deutsch\": \"die Moral (Sg.)\",","    \"turkisch\": \"ahlak, moral\",","    \"armenisch\": \"բարոյականություն\",","    \"chinesisch\": \"道德\",","    \"farsi\": \"اخلاق\",","    \"kurdisch\": \"exlaq\",","    \"ukrainisch\": \"мораль\",","    \"beispiel\": \"Die Frage nach der Moral eines Handelns ist oft schwieriger zu beantworten als die nach der Legalität.\",","    \"kapitel\": 7","  },","  {","    \"id\": 569,","    \"deutsch\": \"die Ethik (Sg.)\",","    \"turkisch\": \"etik\",","    \"armenisch\": \"էթիկա\",","    \"chinesisch\": \"伦理\",","    \"farsi\": \"اخلاق\",","    \"kurdisch\": \"etîk\",","    \"ukrainisch\": \"етика\",","    \"beispiel\": \"In der medizinischen Ethik wird oft über die Grenzen der lebensverlängernden Maßnahmen diskutiert.\",","    \"kapitel\": 7","  },","  {","    \"id\": 570,","    \"deutsch\": \"die Norm, -en\",","    \"turkisch\": \"norm\",","    \"armenisch\": \"նորմ\",","    \"chinesisch\": \"规范\",","    \"farsi\": \"هنجار\",","    \"kurdisch\": \"norm\",","    \"ukrainisch\": \"норма\",","    \"beispiel\": \"Gesellschaftliche Norm helfen dabei, das Zusammenleben vieler Menschen friedlich zu gestalten.\",","    \"kapitel\": 7","  },","  {","    \"id\": 571,","    \"deutsch\": \"die Regel, -n\",","    \"turkisch\": \"kural\",","    \"armenisch\": \"կանոն\",","    \"chinesisch\": \"规则\",","    \"farsi\": \"قاعده\",","    \"kurdisch\": \"rêzik\",","    \"ukrainisch\": \"правило\",","    \"beispiel\": \"In diesem Spiel gibt es klare Regel, die von allen Teilnehmern beachtet werden müssen.\",","    \"kapitel\": 7","  },","  {","    \"id\": 572,","    \"deutsch\": \"die Pflicht, -en\",","    \"turkisch\": \"görev, yükümlülük\",","    \"armenisch\": \"պարտականություն\",","    \"chinesisch\": \"义务\",","    \"farsi\": \"وظیفه\",","    \"kurdisch\": \"peywir\",","    \"ukrainisch\": \"обов'язок\",","    \"beispiel\": \"Es ist die moralische Pflicht eines jeden Bürgers, im Rahmen seiner Möglichkeiten Hilfe zu leisten.\",","    \"kapitel\": 7","  },","  {","    \"id\": 573,","    \"deutsch\": \"das Verbrechen, -\",","    \"turkisch\": \"cürüm, suç\",","    \"armenisch\": \"հանցագործություն\",","    \"chinesisch\": \"罪行\",","    \"farsi\": \"جنایت\",","    \"kurdisch\": \"tawan\",","    \"ukrainisch\": \"злочин\",","    \"beispiel\": \"Ein schweres Verbrechen wie Mord verjährt in der deutschen Rechtsprechung niemals.\",","    \"kapitel\": 7","  },","  {","    \"id\": 574,","    \"deutsch\": \"das Opfer, -\",","    \"turkisch\": \"kurban, mağdur\",","    \"armenisch\": \"զոհ\",","    \"chinesisch\": \"受害者\",","    \"farsi\": \"قربانی\",","    \"kurdisch\": \"qurbanî\",","    \"ukrainisch\": \"жертва\",","    \"beispiel\": \"Das Opfer des Überfalls wird psychologisch betreut, um das traumatische Erlebnis zu verarbeiten.\",","    \"kapitel\": 7","  },","  {","    \"id\": 575,","    \"deutsch\": \"die Justiz (Sg.)\",","    \"turkisch\": \"adalet, yargı\",","    \"armenisch\": \"արդարադատություն\",","    \"chinesisch\": \"司法\",","    \"farsi\": \"قوه قضاییه\",","    \"kurdisch\": \"dadwerî\",","    \"ukrainisch\": \"юстиція\",","    \"beispiel\": \"Die Justiz muss unabhängig von politischer Einflussnahme über Recht und Unrecht entscheiden.\",","    \"kapitel\": 7","  },","  {","    \"id\": 576,","    \"deutsch\": \"die Resozialisierung (Sg.)\",","    \"turkisch\": \"yeniden sosyalleştirme\",","    \"armenisch\": \"վերասոցիալականացում\",","    \"chinesisch\": \"重返社会\",","    \"farsi\": \"بازپروری\",","    \"kurdisch\": \"vesosyalîzasyon\",","    \"ukrainisch\": \"ресоціалізація\",","    \"beispiel\": \"Die Resozialisierung von Straftätern ist ein wichtiges Ziel des modernen Strafvollzugs.\",","    \"kapitel\": 7","  },","  {","    \"id\": 577,","    \"deutsch\":