i\": \"آرزو\",","    \"kurdisch\": \"xwestek\",","    \"ukrainisch\": \"бажання\",","    \"beispiel\": \"Es ist mein Herzenswunsch, einmal im Leben eine Weltreise zu unternehmen.\",","    \"kapitel\": 5","  },","  {","    \"id\": 377,","    \"deutsch\": \"das Ziel, -e\",","    \"turkisch\": \"hedef\",","    \"armenisch\": \"նպատակ\",","    \"chinesisch\": \"目标\",","    \"farsi\": \"هدف\",","    \"kurdisch\": \"armanc\",","    \"ukrainisch\": \"мета\",","    \"beispiel\": \"Das oberste Ziel unserer Unternehmensstrategie ist die Erhöhung der Kundenzufriedenheit.\",","    \"kapitel\": 5","  },","  {","    \"id\": 378,","    \"deutsch\": \"die Zufriedenheit (Sg.)\",","    \"turkisch\": \"memnuniyet\",","    \"armenisch\": \"գոհունակություն\",","    \"chinesisch\": \"满意\",","    \"farsi\": \"رضایت\",","    \"kurdisch\": \"razîbûn\",","    \"ukrainisch\": \"задоволення\",","    \"beispiel\": \"Die allgemeine Zufriedenheit der Mitarbeiter hat sich nach der Gehaltserhöhung deutlich verbessert.\",","    \"kapitel\": 5","  },","  {","    \"id\": 379,","    \"deutsch\": \"der Zweck, -e\",","    \"turkisch\": \"amaç\",","    \"armenisch\": \"նպատակ\",","    \"chinesisch\": \"目的\",","    \"farsi\": \"هدف\",","    \"kurdisch\": \"armanc\",","    \"ukrainisch\": \"мета\",","    \"beispiel\": \"Diese neue Regelung dient ausschließlich dem Zweck, die Sicherheit der Passagiere zu erhöhen.\",","    \"kapitel\": 5","  },","  {","    \"id\": 380,","    \"deutsch\": \"der Zweifel, -\",","    \"turkisch\": \"şüphe\",","    \"armenisch\": \"կասկած\",","    \"chinesisch\": \"怀疑\",","    \"farsi\": \"شک\",","    \"kurdisch\": \"guman\",","    \"ukrainisch\": \"сумнів\",","    \"beispiel\": \"Trotz seiner gründlichen Vorbereitung hatte er immer noch leise Zweifel am Erfolg des Projekts.\",","    \"kapitel\": 5","  },","  {","    \"id\": 381,","    \"deutsch\": \"der Zeitdruck (Sg.)\",","    \"turkisch\": \"zaman baskısı\",","    \"armenisch\": \"ժամանակի սղություն\",","    \"chinesisch\": \"时间压力\",","    \"farsi\": \"فشار زمانی\",","    \"kurdisch\": \"zexta demê\",","    \"ukrainisch\": \"тиск часу\",","    \"beispiel\": \"Unter ständigem Zeitdruck leidet oft die Qualität der Arbeit und die Gesundheit der Angestellten.\",","    \"kapitel\": 5","  },","  {","    \"id\": 382,","    \"deutsch\": \"die Anerkennung, -en\",","    \"turkisch\": \"tanınma\",","    \"armenisch\": \"ճանաչում\",","    \"chinesisch\": \"认可\",","    \"farsi\": \"قدردانی\",","    \"kurdisch\": \"nasîn\",","    \"ukrainisch\": \"визнання\",","    \"beispiel\": \"Die öffentliche Anerkennung seiner Verdienste war für ihn ein sehr bewegender Moment.\",","    \"kapitel\": 5","  },","  {","    \"id\": 383,","    \"deutsch\": \"der Antrieb, -e\",","    \"turkisch\": \"dürtü\",","    \"armenisch\": \"մղում\",","    \"chinesisch\": \"动力\",","    \"farsi\": \"انگیزه\",","    \"kurdisch\": \"handan\",","    \"ukrainisch\": \"спонукання\",","    \"beispiel\": \"Ihr starker innerer Antrieb ermöglichte es ihr, das anspruchsvolle Studium in Rekordzeit abzuschließen.\",","    \"kapitel\": 5","  },","  {","    \"id\": 384,","    \"deutsch\": \"die Anweisung, -en\",","    \"turkisch\": \"talimat\",","    \"armenisch\": \"հրահանգ\",","    \"chinesisch\": \"指示\",","    \"farsi\": \"دستورالعمل\",","    \"kurdisch\": \"rêwerz\",","    \"ukrainisch\": \"вказівка\",","    \"beispiel\": \"Alle Mitarbeiter sind verpflichtet, die schriftlichen Anweisung zur Arbeitssicherheit genau zu befolgen.\",","    \"kapitel\": 5","  },","  {","    \"id\": 385,","    \"deutsch\": \"die Arbeitsatmosphäre (Sg.)\",","    \"turkisch\": \"çalışma atmosferi\",","    \"armenisch\": \"աշխատանքային մթնոլորտ\",","    \"chinesisch\": \"工作氛围\",","    \"farsi\": \"جو کاری\",","    \"kurdisch\": \"atmosfera kar\",","    \"ukrainisch\": \"робоча атмосфера\",","    \"beispiel\": \"Eine kollegiale Arbeitsatmosphäre ist oft wichtiger für die Motivation als ein hohes Gehalt.\",","    \"kapitel\": 5","  },","  {","    \"id\": 386,","    \"deutsch\": \"das Arbeitsentgelt, -e\",","    \"turkisch\": \"ücret\",","    \"armenisch\": \"աշխատավարձ\",","    \"chinesisch\": \"工资\",","    \"farsi\": \"دستمزد\",","    \"kurdisch\": \"mûçe\",","    \"ukrainisch\": \"заробітна плата\",","    \"beispiel\": \"Das monatliche Arbeitsentgelt wird pünktlich zum ersten Werktag auf das Konto überwiesen.\",","    \"kapitel\": 5","  },","  {","    \"id\": 387,","    \"deutsch\": \"der Aufstieg, -e\",","    \"turkisch\": \"yükselme\",","    \"armenisch\": \"առաջխաղացում\",","    \"chinesisch\": \"晋升\",","    \"farsi\": \"ارتقاء\",","    \"kurdisch\": \"pêşketin\",","    \"ukrainisch\": \"просування\",","    \"beispiel\": \"Ein schneller Aufstieg innerhalb der Firma ist nur bei überdurchschnittlichen Leistungen möglich.\",","    \"kapitel\": 5","  },","  {","    \"id\": 388,","    \"deutsch\": \"die Autonomie, -n\",","    \"turkisch\": \"özerklik\",","    \"armenisch\": \"ինքնավարություն\",","    \"chinesisch\": \"自主\",","    \"farsi\": \"استقلال\",","    \"kurdisch\": \"xweserî\",","    \"ukrainisch\": \"автономія\",","    \"beispiel\": \"Viel Autonomie bei der Gestaltung der eigenen Aufgaben fördert die Kreativität im Team.\",","    \"kapitel\": 5","  },","  {","    \"id\": 389,","    \"deutsch\": \"die Begeisterung (Sg.)\",","    \"turkisch\": \"coşku\",","    \"armenisch\": \"ոգևորություն\",","    \"chinesisch\": \"热情\",","    \"farsi\": \"شور و شوق\",","    \"kurdisch\": \"coş\",","    \"ukrainisch\": \"захоплення\",","    \"beispiel\": \"Die Begeisterung der Fans im Stadion war während des gesamten Spiels fast greifbar.\",","    \"kapitel\": 5","  },","  {","    \"id\": 390,","    \"deutsch\": \"der Einfluss, \\\"-e\",","    \"turkisch\": \"etki\",","    \"armenisch\": \"ազդեցություն\",","    \"chinesisch\": \"影响\",","    \"farsi\": \"تاثیر\",","    \"kurdisch\": \"bandor\",","    \"ukrainisch\": \"вплив\",","    \"beispiel\": \"Die sozialen Medien haben heute einen enormen Einfluss auf die öffentliche Meinungsbildung.\",","    \"kapitel\": 5","  },","  {","    \"id\": 391,","    \"deutsch\": \"die Entlohnung, -en\",","    \"turkisch\": \"ücretlendirme\",","    \"armenisch\": \"վարձատրություն\",","    \"chinesisch\": \"报酬\",","    \"farsi\": \"پاداش\",","    \"kurdisch\": \"xelat\",","    \"ukrainisch\": \"винагорода\",","    \"beispiel\": \"Eine faire Entlohnung ist die Basis für ein respektvolles Verhältnis zwischen Arbeitgeber und Arbeitnehmer.\",","    \"kapitel\": 5","  },","  {","    \"id\": 392,","    \"deutsch\": \"die Freude, -n\",","    \"turkisch\": \"sevinç\",","    \"armenisch\": \"ուրախություն\",","    \"chinesisch\": \"快乐\",","    \"farsi\": \"شادی\",","    \"kurdisch\": \"şahî\",","    \"ukrainisch\": \"радість\",","    \"beispiel\": \"Es bereitet ihm große Freude, sein Wissen an die jüngeren Kollegen weiterzugeben.\",","    \"kapitel\": 5","  },","  {","    \"id\": 393,","    \"deutsch\": \"die Gehaltserhöhung, -en\",","    \"turkisch\": \"maaş zammı\",","    \"armenisch\": \"աշխատավարձի բարձրացում\",","    \"chinesisch\": \"加薪\",","    \"farsi\": \"افزایش حقوق\",","    \"kurdisch\": \"bilindkirina mûçeyê\",","    \"ukrainisch\": \"підвищення зарплати\",","    \"beispiel\": \"Eine moderate Gehaltserhöhung wurde im Rahmen der letzten Tarifverhandlungen vereinbart.\",","    \"kapitel\": 5","  },","  {","    \"id\": 394,","    \"deutsch\": \"die Identifikation (Sg.)\",","    \"turkisch\": \"özdeşleşme\",","    \"armenisch\": \"նույնականացում\",","    \"chinesisch\": \"认同\",","    \"farsi\": \"هویت یابی\",","    \"kurdisch\": \"nasname\",","    \"ukrainisch\": \"ідентифікація\",","    \"beispiel\": \"Die starke Identifikation der Mitarbeiter mit den Unternehmenszielen ist ein großer Erfolgsfaktor.\",","    \"kapitel\": 5","  },","  {","    \"id\": 395,","    \"deutsch\": \"das Image, -s\",","    \"turkisch\": \"imaj\",","    \"armenisch\": \"իմիջ\",","    \"chinesisch\": \"形象\",","    \"farsi\": \"تصویر\",","    \"kurdisch\": \"îmaj\",","    \"ukrainisch\": \"імідж\",","    \"beispiel\": \"Das positive Image der Marke wurde durch die erfolgreiche Marketingkampagne weiter gestärkt.\",","    \"kapitel\": 5","  },","  {","    \"id\": 396,","    \"deutsch\": \"der Impuls, -e\",","    \"turkisch\": \"dürtü\",","    \"armenisch\": \"ազդակ\",","    \"chinesisch\": \"冲动\",","    \"farsi\": \"انگیزه\",","    \"kurdisch\": \"impuls\",","    \"ukrainisch\": \"імпульс\",","    \"beispiel\": \"Ein kleiner Impuls von außen reicht oft aus, um einen großen Veränderungsprozess in Gang zu setzen.\",","    \"kapitel\": 5","  },","  {","    \"id\": 397,","    \"deutsch\": \"das Konzept, -e\",","    \"turkisch\": \"konsept\",","    \"armenisch\": \"հայեցակարգ\",","    \"chinesisch\": \"概念\",","    \"farsi\": \"مفهوم\",","    \"kurdisch\": \"konsept\",","    \"ukrainisch\": \"концепція\",","    \"beispiel\": \"Das neue pädagogische Konzept der Schule setzt auf individuelles Lernen und Projektarbeit.\",","    \"kapitel\": 5","  },","  {","    \"id\": 398,","    \"deutsch\": \"die Kreativität (Sg.)\",","    \"turkisch\": \"yaratıcılık\",","    \"armenisch\": \"ստեղծագործականություն\",","    \"chinesisch\": \"创造力\",","    \"farsi\": \"خلاقیت\",","    \"kurdisch\": \"afirînerî\",","    \"ukrainisch\": \"творчість\",","    \"beispiel\": \"Die Förderung der Kreativität sollte bereits im frühen Kindesalter in der Schule beginnen.\",","    \"kapitel\": 5","  },","  {","    \"id\": 399,","    \"deutsch\": \"das Lob, -e\",","    \"turkisch\": \"övgü\",","    \"armenisch\": \"գովասանք\",","    \"chinesisch\": \"表扬\",","    \"farsi\": \"تحسین\",","    \"kurdisch\": \"pesn\",","    \"ukrainisch\": \"похвала\",","    \"beispiel\": \"Ein aufrichtiges Lob zur rechten Zeit kann die Motivation eines Mitarbeiters enorm steigern.\",","    \"kapitel\": 5","  },","  {","    \"id\": 400,","    \"deutsch\": \"die Motivation, -en\",","    \"turkisch\": \"motivasyon\",","    \"armenisch\": \"մոտիվացիա\",","    \"chinesisch\": \"动机\",","    \"farsi\": \"انگیزه\",","    \"kurdisch\": \"motîvasyon\",","    \"ukrainisch\": \"мотивація\",","    \"beispiel\": \"Die intrinsische Motivation ist meistens dauerhafter als Anreize durch rein finanzielle Belohnungen.\",","    \"kapitel\": 5","  },","  {","    \"id\": 401,","    \"deutsch\": \"der Reiz, -e\",","    \"turkisch\": \"uyarıcı\",","    \"armenisch\": \"գրգիռ\",","    \"chinesisch\": \"刺激\",","    \"farsi\": \"محرک\",","    \"kurdisch\": \"teşwîq\",","    \"ukrainisch\": \"подразник\",","    \"beispiel\": \"Ein neuer Reiz, wie eine spannende Aufgabe, kann die Lernmotivation der Schüler erheblich steigern.\",","    \"kapitel\": 5","  },","  {","    \"id\": 402,","    \"deutsch\": \"die Sicherheit, -en\",","    \"turkisch\": \"güvenlik\",","    \"armenisch\": \"անվտանգություն\",","    \"chinesisch\": \"安全\",","    \"farsi\": \"امنیت\",","    \"kurdisch\": \"ewlehî\",","    \"ukrainisch\": \"безпека\",","    \"beispiel\": \"In Zeiten wirtschaftlicher Unsicherheit ist die Sicherheit des Arbeitsplatzes für viele Menschen das wichtigste Kriterium.\",","    \"kapitel\": 5","  },","  {","    \"id\": 403,","    \"deutsch\": \"der Status (Sg.)\",","    \"turkisch\": \"statü\",","    \"armenisch\": \"կարգավիճակ\",","    \"chinesisch\": \"地位\",","    \"farsi\": \"وضعیت\",","    \"kurdisch\": \"statu\",","    \"ukrainisch\": \"статус\",","    \"beispiel\": \"Der soziale Status eines Menschen sollte nicht nur über seinen materiellen Besitz definiert werden.\",","    \"kapitel\": 5","  },","  {","    \"id\": 404,","    \"deutsch\": \"der/die Vorgesetzte, -n\",","    \"turkisch\": \"amir\",","    \"armenisch\": \"ղեկավար\",","    \"chinesisch\": \"上司\",","    \"farsi\": \"مافوق\",","    \"kurdisch\": \"serpereşt\",","    \"ukrainisch\": \"керівник\",","    \"beispiel\": \"Ein kooperativer Führungsstil des Vorgesetzte fördert das Vertrauen und die Leistungsbereitschaft im Team.\",","    \"kapitel\": 5","  },","  {","    \"id\": 405,","    \"deutsch\": \"die Wertschätzung (Sg.)\",","    \"turkisch\": \"takdir\",","    \"armenisch\": \"գնահատանք\",","    \"chinesisch\": \"赞赏\",","    \"farsi\": \"قدردانی\",","    \"kurdisch\": \"qedir\",","    \"ukrainisch\": \"вдячність\",","    \"beispiel\": \"Ehrliche Wertschätzung für die geleistete Arbeit ist oft effektiver als rein finanzielle Bonus Zahlungen.\",","    \"kapitel\": 5","  },","  {","    \"id\": 406,","    \"deutsch\": \"die Zugehörigkeit (Sg.)\",","    \"turkisch\": \"aidiyet\",","    \"armenisch\": \"պատկանելիություն\",","    \"chinesisch\": \"归属感\",","    \"farsi\": \"تعلق\",","    \"kurdisch\": \"aîdiyet\",","    \"ukrainisch\": \"приналежність\",","    \"beispiel\": \"Das Gefühl der Zugehörigkeit zu einer sozialen Gruppe ist ein menschliches Grundbedürfnis.\",","    \"kapitel\": 5","  },","  {","    \"id\": 407,","    \"deutsch\": \"die Anregung, -en\",","    \"turkisch\": \"teşvik\",","    \"armenisch\": \"խթանում\",","    \"chinesisch\": \"刺激\",","    \"farsi\": \"تحریک\",","    \"kurdisch\": \"teşwîq\",","    \"ukrainisch\": \"стимуляція\",","    \"beispiel\": \"Die wertvollen Anregung der Experten wurden direkt in die Überarbeitung des Projekts einbezogen.\",","    \"kapitel\": 6","  },","  {","    \"id\": 408,","    \"deutsch\": \"die Auswirkung, -en\",","    \"turkisch\": \"etki, sonuç\",","    \"armenisch\": \"ազդեցություն\",","    \"chinesisch\": \"影响\",","    \"farsi\": \"تأثیر\",","    \"kurdisch\": \"bandor\",","    \"ukrainisch\": \"вплив\",","    \"beispiel\": \"Die langfristige Auswirkung der Umweltverschmutzung auf die Gesundheit sind noch nicht vollständig erforscht.\",","    \"kapitel\": 6","  },","  {","    \"id\": 409,","    \"deutsch\": \"das Bedürfnis, -se\",","    \"turkisch\": \"ihtiyaç\",","    \"armenisch\": \"կարիք\",","    \"chinesisch\": \"需求\",","    \"farsi\": \"نیاز\",","    \"kurdisch\": \"pêdivî\",","    \"ukrainisch\": \"потреба\",","    \"beispiel\": \"Jeder Mensch hat individuelle Bedürfnis, die in einer Partnerschaft berücksichtigt werden sollten.\",","    \"kapitel\": 6","  },","  {","    \"id\": 410,","    \"deutsch\": \"der Befund, -e\",","    \"turkisch\": \"bulgu\",","    \"armenisch\": \"եզրակացություն\",","    \"chinesisch\": \"结果\",","    \"farsi\": \"یافته\",","    \"kurdisch\": \"dîtin\",","    \"ukrainisch\": \"висновок\",","    \"beispiel\": \"Der medizinische Befund des Arztes bestätigte leider den Verdacht auf eine chronische Erkrankung.\",","    \"kapitel\": 6","  },","  {","    \"id\": 411,","    \"deutsch\": \"die Belastung, -en\",","    \"turkisch\": \"yük, stres\",","    \"armenisch\": \"բեռ\",","    \"chinesisch\": \"负担\",","    \"farsi\": \"بار\",","    \"kurdisch\": \"bar\",","    \"ukrainisch\": \"навантаження\",","    \"beispiel\": \"Die psychische Belastung am Arbeitsplatz hat durch die ständige Erreichbarkeit deutlich zugenommen.\",","    \"kapitel\": 6","  },","  {","    \"id\": 412,","    \"deutsch\": \"die Dosis, Dosen\",","    \"turkisch\": \"doz\",","    \"armenisch\": \"դոզա\",","    \"chinesisch\": \"剂量\",","    \"farsi\": \"دوز\",","    \"kurdisch\": \"doz\",","    \"ukrainisch\": \"доза\",","    \"beispiel\": \"Bei Medikamenten ist die richtige Dosis entscheidend für den Heilungserfolg und die Vermeidung von Nebenwirkungen.\",","    \"kapitel\": 6","  },","  {","    \"id\": 413,","    \"deutsch\": \"der Entzug, \\\"-e\",","    \"turkisch\": \"yoksunluk\",","    \"armenisch\": \"զրկում\",","    \"chinesisch\": \"戒断\",","    \"farsi\": \"ترک\",","    \"kurdisch\": \"vekişîn\",","    \"ukrainisch\": \"абстиненція\",","    \"beispiel\": \"Der plötzliche Entzug von Koffein kann bei manchen Menschen zu starken Kopfschmerzen führen.\",","    \"kapitel\": 6","  },","  {","    \"id\": 414,","    \"deutsch\": \"die Erbanlage, -n\",","    \"turkisch\": \"genetik yatkınlık\",","    \"armenisch\": \"ժառանգական նախատրամադրվածություն\",","    \"chinesisch\": \"遗传倾向\",","    \"farsi\": \"استعداد ژنتیکی\",","    \"kurdisch\": \"meyla genetîkî\",","    \"ukrainisch\": \"генетична схильність\",","    \"beispiel\": \"Obwohl die Erbanlage eine Rolle spielen, hat auch der Lebensstil einen großen Einfluss auf die Gesundheit.\",","    \"kapitel\": 6","  },","  {","    \"id\": 415,","    \"deutsch\": \"die Ernährung, -en\",","    \"turkisch\": \"beslenme\",","    \"armenisch\": \"սնուցում\",","    \"chinesisch\": \"营养\",","    \"farsi\": \"تغذیه\",","    \"kurdisch\": \"xwarin\",","    \"ukrainisch\": \"харчування\",","    \"beispiel\": \"Eine ausgewogene Ernährung mit viel Obst und Gemüse ist die Basis für ein starkes Immunsystem.\",","    \"kapitel\": 6","  },","  {","    \"id\": 416,","    \"deutsch\": \"der Feind, -e\",","    \"turkisch\": \"düşman\",","    \"armenisch\": \"թշնամի\",","    \"chinesisch\": \"敌人\",","    \"farsi\": \"دشمن\",","    \"kurdisch\": \"dijmin\",","    \"ukrainisch\": \"ворог\",","    \"beispiel\": \"Stress gilt heute als einer der größten Feind der modernen Volksgesundheit.\",","    \"kapitel\": 6","  },","  {","    \"id\": 417,","    \"deutsch\": \"der/die Forscher/in, -/-nen\",","    \"turkisch\": \"araştırmacı\",","    \"armenisch\": \"հետազոտող\",","    \"chinesisch\": \"研究员\",","    \"farsi\": \"پژوهشگر\",","    \"kurdisch\": \"lêkolîner\",","    \"ukrainisch\": \"дослідник\",","    \"beispiel\": \"Der/die Forscher/in veröffentlichte die bahnbrechenden Ergebnisse ihrer Studie in einem renommierten Fachmagazin.\",","    \"kapitel\": 6","  },","  {","    \"id\": 418,","    \"deutsch\": \"der Geist, -er\",","    \"turkisch\": \"ruh, zihin\",","    \"armenisch\": \"ոգի, միտք\",","    \"chinesisch\": \"精神\",","    \"farsi\": \"روح, ذهن\",","    \"kurdisch\": \"ruh, hiş\",","    \"ukrainisch\": \"дух, розум\",","    \"beispiel\": \"Ein wacher Geist und lebenslange Neugier sind gute Voraussetzungen für ein gesundes Altern.\",","    \"kapitel\": 6","  },","  {","    \"id\": 419,","    \"deutsch\": \"die Genehmigung, -en\",","    \"turkisch\": \"onay, izin\",","    \"armenisch\": \"թույլտվություն\",","    \"chinesisch\": \"批准\",","    \"farsi\": \"مجوز\",","   