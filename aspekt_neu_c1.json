heit, -en\",","    \"turkisch\": \"hastalık\",","    \"armenisch\": \"հիվանդություն\",","    \"chinesisch\": \"疾病\",","    \"farsi\": \"بیماری\",","    \"kurdisch\": \"nexweşî\",","    \"ukrainisch\": \"хвороба\",","    \"beispiel\": \"Die Prävention chronischer Krankheit ist ein zentrales Ziel der modernen Gesundheitspolitik.\",","    \"kapitel\": 6","  },","  {","    \"id\": 430,","    \"deutsch\": \"der Kreislauf, \\\"-e\",","    \"turkisch\": \"dolaşım\",","    \"armenisch\": \"արյան շրջանառություն\",","    \"chinesisch\": \"循环\",","    \"farsi\": \"گردش خون\",","    \"kurdisch\": \"gera xwînê\",","    \"ukrainisch\": \"кровообіг\",","    \"beispiel\": \"Ausreichend Schlaf ist essenziell, damit sich der Kreislauf und das Nervensystem regenerieren können.\",","    \"kapitel\": 6","  },","  {","    \"id\": 431,","    \"deutsch\": \"das Merkmal, -e\",","    \"turkisch\": \"özellik\",","    \"armenisch\": \"հատկանիշ\",","    \"chinesisch\": \"特征\",","    \"farsi\": \"ویژگی\",","    \"kurdisch\": \"taybetmendî\",","    \"ukrainisch\": \"ознака\",","    \"beispiel\": \"Ein typisches Merkmal dieser Erkrankung ist ein plötzlicher Verlust des Geruchssinns.\",","    \"kapitel\": 6","  },","  {","    \"id\": 432,","    \"deutsch\": \"der Muskel, -n\",","    \"turkisch\": \"kas\",","    \"armenisch\": \"մկան\",","    \"chinesisch\": \"肌肉\",","    \"farsi\": \"عضله\",","    \"kurdisch\": \"masûlke\",","    \"ukrainisch\": \"м'яз\",","    \"beispiel\": \"Gezieltes Krafttraining hilft dabei, die Muskel aufzubauen und die Gelenke zu stabilisieren.\",","    \"kapitel\": 6","  },","  {","    \"id\": 433,","    \"deutsch\": \"die Psyche, -n\",","    \"turkisch\": \"ruh, psişe\",","    \"armenisch\": \"հոգի\",","    \"chinesisch\": \"心理\",","    \"farsi\": \"روان\",","    \"kurdisch\": \"psîkolojî\",","    \"ukrainisch\": \"психіка\",","    \"beispiel\": \"Körperliche Beschwerden können oft eine tiefe Ursache in der menschlichen Psyche haben.\",","    \"kapitel\": 6","  },","  {","