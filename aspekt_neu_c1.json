enisch\": \"պատյան\",","    \"chinesisch\": \"外壳\",","    \"farsi\": \"پوسته\",","    \"kurdisch\": \"qalik\",","    \"ukrainisch\": \"оболонка\",","    \"beispiel\": \"Oft ist die schöne Verpackung nur eine Hülle, die über einen leeren Inhalt hinwegtäuscht.\",","    \"kapitel\": 8","  },","  {","    \"id\": 587,","    \"deutsch\": \"der Kern, -e\",","    \"turkisch\": \"öz, çekirdek\",","    \"armenisch\": \"միջուկ\",","    \"chinesisch\": \"核心\",","    \"farsi\": \"هسته\",","    \"kurdisch\": \"navik\",","    \"ukrainisch\": \"ядро\",","    \"beispiel\": \"Man muss zum Kern eines Problems vordringen, um eine dauerhafte Lösung zu finden.\",","    \"kapitel\": 8","  },","  {","    \"id\": 588,","    \"deutsch\": \"die Kleidung (Sg.)\",","    \"turkisch\": \"giysi, kıyafet\",","    \"armenisch\": \"հագուստ\",","    \"chinesisch\": \"服装\",","    \"farsi\": \"لباس\",","    \"kurdisch\": \"cil\",","    \"ukrainisch\": \"одяг\",","    \"beispiel\": \"Angemessene Kleidung wird bei diesem festlichen Empfang ausdrücklich vorausgesetzt.\",","    \"kapitel\": 8","  },","  {","    \"id\": 589,","    \"deutsch\": \"die Kosmetik (Sg.)\",","    \"turkisch\": \"kozmetik\",","    \"armenisch\": \"կոսմետիկա\",","    \"chinesisch\": \"化妆品\",","    \"farsi\": \"لوازم آرایش\",","    \"kurdisch\": \"kozmetîk\",","    \"ukrainisch\": \"косметика\",","    \"beispiel\": \"Die Industrie für Kosmetik erzielt jährlich Milliardenumsätze mit Produkten zur Hautpflege.\",","    \"kapitel\": 8","  },","  {","    \"id\": 590,","    \"deutsch\": \"die Makellosigkeit (Sg.)\",","    \"turkisch\": \"kusursuzluk\",","    \"armenisch\": \"անթերիություն\",","    \"chinesisch\": \"完美无瑕\",","    \"farsi\": \"بی عیب و نقص بودن\",","    \"kurdisch\": \"bêkêmasîbûn\",","    \"ukrainisch\": \"бездоганність\",","    \"beispiel\": \"Das Streben nach absoluter Makellosigkeit in den sozialen Medien setzt viele junge Menschen unter Druck.\",","    \"kapitel\": 8","  },","  {","    \"id\": 591,","    \"deutsch\": \"d