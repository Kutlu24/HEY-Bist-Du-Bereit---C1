 \"beispiel\": \"Die festen Büroplätze wichen flexiblen Arbeitsplatzmodellen.\",","    \"lektion\": 4,","    \"audio\": \"249.opus\",","    \"teil\": 8","  },","  {","    \"id\": 250,","    \"wort\": \"aufnehmen\",","    \"grammatik\": \"nimmt auf, nahm auf, hat aufgenommen\",","    \"beispiel\": \"Diese Veränderungen wurden von den Mitarbeitenden positiv aufgenommen.\",","    \"lektion\": 4,","    \"audio\": \"250.opus\",","    \"teil\": 8","  },","  {","    \"id\": 251,","    \"wort\": \"einbinden\",","    \"grammatik\": \"bindet ein, band ein, hat eingebunden\",","    \"beispiel\": \"Sie wollte die Mitarbeitenden aktiv in den Prozess einbinden.\",","    \"lektion\": 4,","    \"audio\": \"251.opus\",","    \"teil\": 8","  },","  {","    \"id\": 252,","    \"wort\": \"gelingen\",","    \"grammatik\": \"gelingt, gelang, ist gelungen\",","    \"beispiel\": \"Es gelang ihr, als Frau in einer von Männern dominierten Branche erfolgreich zu sein.\",","    \"lektion\": 4,","    \"audio\": \"252.opus\",","    \"teil\": 8","  },","  {","    \"id\": 253,","    \"wort\": \"golden\",","    \"grammatik\": \"\",","    \"beispiel\": \"Die grösste Herausforderung ist, den goldenen Mittelweg zu finden.\",","    \"lektion\": 4,","    \"audio\": \"253.opus\",","    \"teil\": 8","  },","  {","    \"id\": 254,","    \"wort\": \"orientiert\",","    \"grammatik\": \"an + Dativ\",","    \"beispiel\": \"Der klassische Führungsstil ist an wirtschaftlichen Erfolgszielen orientiert.\",","    \"lektion\": 4,","    \"audio\": \"254.opus\",","    \"teil\": 8","  },","  {","    \"id\": 255,","    \"wort\": \"Freude\",","    \"grammatik\": \"an + Dativ\",","    \"beispiel\": \"Ebenso wichtig ist, die Freude an der Arbeit zu erhalten.\",","    \"lektion\": 4,","    \"audio\": \"255.opus\",","    \"teil\": 8","  },","  {","    \"id\": 256,","    \"wort\": \"vertrauensvoll\",","    \"grammatik\": \"\",","    \"beispiel\": \"Bei der Arbeit sollte ein vertrauensvolles Miteinander herrschen.\",","    \"